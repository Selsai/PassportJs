# Le fichier ".env" ne doit JAMAIS être poussé sur GitHub (voir .gitignore).

PORT=5000
CLIENT_URL=http://localhost:3000

# Clé utilisée pour signer les cookies de session (mets n'importe quelle chaîne aléatoire longue)
SESSION_KEY=remplace_moi_par_une_chaine_aleatoire_longue

# Google Cloud Console > Google Auth Platform > Clients
GOOGLE_CLIENT_ID=TON_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TON_SECRET

# GitHub > Settings > Developer settings > OAuth Apps
GITHUB_CLIENT_ID=TON_ID_GITHUB
GITHUB_CLIENT_SECRET=TON_SECRET_GITHUB